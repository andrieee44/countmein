syntax = "proto3";

package calendars.v2;

import "google/protobuf/timestamp.proto";

service CalendarService {
  rpc CreateCalendar(CreateCalendarRequest) returns (CreateCalendarResponse);
  rpc GetCalendar(GetCalendarRequest) returns (GetCalendarResponse);
  rpc GetCalendarWrites(GetCalendarWritesRequest) returns (GetCalendarWritesResponse);
  rpc WriteCalendar(WriteCalendarRequest) returns (WriteCalendarResponse);
  rpc UpdateCalendarMetadata(UpdateCalendarMetadataRequest) returns (UpdateCalendarMetadataResponse);
  rpc DeleteCalendar(DeleteCalendarRequest) returns (DeleteCalendarResponse);
}

message CreateCalendarRequest {
  string name = 1;
  bytes ical = 2;
  string color = 4;
  optional string description = 5;
}

message CreateCalendarResponse {
  int64 calendar_id = 1;
}

message GetCalendarRequest {
  int64 calendar_id = 1;
}

message GetCalendarResponse {
  int64 owner_user_id = 1;
  string name = 2;
  string color = 3;
  bytes ical = 4;
  google.protobuf.Timestamp updated_at = 5;
  optional string description = 6;
}

message GetCalendarWritesRequest {
  int64 calendar_id = 1;
}

message GetCalendarWritesResponse {
  repeated int64 calendar_write_event_ids = 1;
}

message WriteCalendarRequest {
  int64 calendar_id = 1;
  bytes ical = 2;
}

message WriteCalendarResponse {}

message UpdateCalendarMetadataRequest {
  int64 calendar_id = 1;
  optional string name = 2;
  optional string color = 3;
  optional string description = 4;
}

message UpdateCalendarMetadataResponse {}

message DeleteCalendarRequest {
  int64 calendar_id = 1;
}

message DeleteCalendarResponse {}
